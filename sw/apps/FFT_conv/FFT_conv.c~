#include <k5_libs.h>
#include <stdint.h>
#include <stddef.h>
#include <math.h>

/*==============================================================================
    FFT_conv - v15 (FULL FFT INTEGRATION)
    - Naive Conv: O(N^2)
    - FFT Conv: O(N log N) using float complex numbers
==============================================================================*/

#define MAX_N 256
#ifndef OUT_SHIFT
#define OUT_SHIFT 0
#endif

typedef struct {
    int32_t n; int32_t mode;
    volatile int8_t* c; volatile int8_t* x; volatile uint8_t* y_u8;
} cfg_t;

static volatile int8_t  g_in_buf[2 * MAX_N] __attribute__((aligned(16)));
static volatile uint8_t g_y_u8_buf[MAX_N]   __attribute__((aligned(16)));

typedef struct { float re, im; } cfloat_t;
static cfloat_t g_C[MAX_N], g_X[MAX_N], g_Y[MAX_N];

/* --- עזרי FFT --- */
static inline cfloat_t cmul(cfloat_t a, cfloat_t b) {
    cfloat_t r = { a.re*b.re - a.im*b.im, a.re*b.im + a.im*b.re };
    return r;
}

static void fft_inplace(cfloat_t* a, int n, int inverse) {
    // 1. Bit-reversal reordering
    int j = 0;
    for (int i = 1; i < n; ++i) {
        int bit = n >> 1;
        while (j & bit) { j ^= bit; bit >>= 1; }
        j ^= bit;
        if (i < j) { cfloat_t tmp = a[i]; a[i] = a[j]; a[j] = tmp; }
    }

    // 2. Butterfly stages
    
    const float PI = 3.1415926535f;
    for (int len = 2; len <= n; len <<= 1) {
        float ang = 2.0f * PI / len * (inverse ? 1 : -1);
        cfloat_t wlen = { cosf(ang), sinf(ang) };
        for (int i = 0; i < n; i += len) {
            cfloat_t w = { 1, 0 };
            for (int k = 0; k < len / 2; ++k) {
                cfloat_t u = a[i + k];
                cfloat_t v = cmul(a[i + k + len/2], w);
                a[i + k].re = u.re + v.re;
                a[i + k].im = u.im + v.im;
                a[i + k + len/2].re = u.re - v.re;
                a[i + k + len/2].im = u.im - v.im;
                w = cmul(w, wlen);
            }
        }
    }
    if (inverse) {
        for (int i = 0; i < n; i++) { a[i].re /= n; a[i].im /= n; }
    }
}

/* --- מימוש קונבולוציה מבוססת FFT --- */
static void conv_fft_sw(const cfg_t* cfg) {
    int n = cfg->n;
    // א. העברה לפורמט מרוכב
    for (int i = 0; i < n; i++) {
        g_C[i].re = (float)cfg->c[i]; g_C[i].im = 0;
        g_X[i].re = (float)cfg->x[i]; g_X[i].im = 0;
    }

    // ב. FFT לשני הוקטורים
    fft_inplace(g_C, n, 0);
    fft_inplace(g_X, n, 0);

    // ג. כפל נקודתי במישור התדר
    
    for (int i = 0; i < n; i++) {
        g_Y[i] = cmul(g_C[i], g_X[i]);
    }

    // ד. IFFT חזרה למישור הזמן
    fft_inplace(g_Y, n, 1);

    // ה. חילוץ ורוויה (Saturation)
    for (int i = 0; i < n; i++) {
        int32_t res = (int32_t)(g_Y[i].re + 0.5f); // עיגול
        if (res > 127) res = 127; else if (res < -128) res = -128;
        cfg->y_u8[i] = (uint8_t)res;
    }
}

/* --- פונקציית Naive --- */
static void conv_naive_sw(const cfg_t* cfg) {
    int n = cfg->n;
    for (int k = 0; k < n; ++k) {
        int32_t acc = 0;
        for (int i = 0; i < n; ++i) {
            acc += (int32_t)((int8_t)cfg->c[i]) * (int32_t)((int8_t)cfg->x[(k - i) & (n - 1)]);
        }
        int32_t res = acc >> OUT_SHIFT;
        if (res > 127) res = 127; else if (res < -128) res = -128;
        cfg->y_u8[k] = (uint8_t)res;
    }
}

int main() {
    bm_printf("\n=== FFT_CONV v15: FULL FFT INTEGRATED ===\n");
    int cfg_f = bm_fopen_r("fft_test_config.txt");
    int data_f = bm_fopen_r("fft_test_in.txt");
    int out_f = bm_fopen_w("fft_test_out.txt");

    cfg_t cfg; uint32_t words[5];
    bm_start_soc_load_hex_file(cfg_f, 20, (unsigned char*)words);
    while (bm_check_soc_load_hex_file() == 0);
    cfg.n = words[3]; cfg.mode = words[4];
    cfg.c = &g_in_buf[0]; cfg.x = &g_in_buf[cfg.n]; cfg.y_u8 = &g_y_u8_buf[0];

    bm_start_soc_load_hex_file(data_f, 2 * cfg.n, (unsigned char*)g_in_buf);
    while (bm_check_soc_load_hex_file() == 0);

    // מדידת Naive
    bm_printf("[TIME_MARK] NAIVE_START\n");
    conv_naive_sw(&cfg);
    bm_printf("[TIME_MARK] NAIVE_END\n");

    // מדידת FFT
    if (cfg.mode >= 1) {
        bm_printf("[TIME_MARK] FFT_START\n");
        conv_fft_sw(&cfg);
        bm_printf("[TIME_MARK] FFT_END\n");
    }

    bm_start_soc_store_hex_file(out_f, cfg.n, 8, (unsigned char*)cfg.y_u8);
    while (bm_check_soc_store_hex_file() == 0);

    bm_fclose(data_f); bm_fclose(cfg_f); bm_fclose(out_f);
    bm_printf("[OK] Done.\n");
    bm_quit_app();
    return 0;
}
