#include <k5_libs.h>
#include <stdint.h>
#include <math.h>

#ifndef M_PI
#define M_PI 3.14159265358979323846
#endif

/**************** CONFIG ****************/

#define MAX_N 256
#define Q15_SHIFT 15
#define Q15_ONE (1 << Q15_SHIFT)

#define FFT_C_ADDR_REG_IDX   0
#define FFT_X_ADDR_REG_IDX   1
#define FFT_Y_ADDR_REG_IDX   2
#define FFT_N_REG_IDX        3
#define FFT_MODE_REG_IDX     4
#define FFT_START_REG_IDX    5
#define FFT_DONE_REG_IDX     6

#define FFT_C_ADDR_REG   ((volatile unsigned int *) (XBOX_REGS_BASE_ADDR + (4 * FFT_C_ADDR_REG_IDX)))
#define FFT_X_ADDR_REG   ((volatile unsigned int *) (XBOX_REGS_BASE_ADDR + (4 * FFT_X_ADDR_REG_IDX)))
#define FFT_Y_ADDR_REG   ((volatile unsigned int *) (XBOX_REGS_BASE_ADDR + (4 * FFT_Y_ADDR_REG_IDX)))
#define FFT_N_REG        ((volatile unsigned int *) (XBOX_REGS_BASE_ADDR + (4 * FFT_N_REG_IDX)))
#define FFT_MODE_REG     ((volatile unsigned int *) (XBOX_REGS_BASE_ADDR + (4 * FFT_MODE_REG_IDX)))
#define FFT_START_REG    ((volatile unsigned int *) (XBOX_REGS_BASE_ADDR + (4 * FFT_START_REG_IDX)))
#define FFT_DONE_REG     ((volatile unsigned int *) (XBOX_REGS_BASE_ADDR + (4 * FFT_DONE_REG_IDX)))

/**************** TYPES ****************/

typedef struct {
    int32_t re;
    int32_t im;
} cq15;

typedef struct fft_conv_config {
    volatile int8_t *c_addr;
    volatile int8_t *x_addr;
    volatile int8_t *y_addr;
    int32_t n;
    int32_t mode;
} fft_conv_config_t;

/**************** GLOBALS ****************/

static cq15 W[MAX_N / 2];
static uint8_t bit_rev_table[MAX_N];

/**************** HELPERS ****************/

static int32_t abs_s32_c(int32_t v) {
    if (v < 0) {
        return -v;
    }

    return v;
}

static inline int32_t q15_mul(int32_t a, int32_t b) {
    int64_t t = (int64_t)a * (int64_t)b;

    t += (1 << (Q15_SHIFT - 1));

    return (int32_t)(t >> Q15_SHIFT);
}

static inline cq15 cq15_mul(cq15 a, cq15 b) {
    cq15 r;

    r.re = q15_mul(a.re, b.re) - q15_mul(a.im, b.im);
    r.im = q15_mul(a.re, b.im) + q15_mul(a.im, b.re);

    return r;
}

/**************** CONFIG LOAD ****************/

static void load_fft_conv_config(int cfg_f, fft_conv_config_t *cfg) {
    uint32_t words[5] = {0};

    bm_printf("\nLoading Configuration file\n\n");

    bm_start_soc_load_hex_file(cfg_f, sizeof(words), (unsigned char*)words);
    while (!bm_check_soc_load_hex_file());

    cfg->c_addr = (int8_t*)(uintptr_t)words[0];
    cfg->x_addr = (int8_t*)(uintptr_t)words[1];
    cfg->y_addr = (int8_t*)(uintptr_t)words[2];
    cfg->n = words[3];
    cfg->mode = words[4];

    bm_printf("Original config addresses:\n");
    bm_printf("c_addr : 0x%08x\n", (unsigned int)(uintptr_t)cfg->c_addr);
    bm_printf("x_addr : 0x%08x\n", (unsigned int)(uintptr_t)cfg->x_addr);
    bm_printf("y_addr : 0x%08x\n", (unsigned int)(uintptr_t)cfg->y_addr);
    bm_printf("n      : %d\n", cfg->n);
    bm_printf("mode   : %d\n\n", cfg->mode);
}

/**************** INPUT LOAD ****************/

static void load_fft_conv_input_data(int data_f, fft_conv_config_t *cfg) {
    int total_bytes = 2 * cfg->n;

    /*
      The Python checker assumes fft_test_in.txt is arranged as:

          C[0..N-1], then X[0..N-1]

      Therefore we force the memory layout to be:

          cfg->c_addr[0..N-1]   = C
          cfg->c_addr[N..2N-1]  = X
          cfg->x_addr           = cfg->c_addr + N

      Important:
      We load the file DIRECTLY into xmem.
      This avoids a possible CPU-cache / accelerator-coherency issue.
    */

    volatile int8_t *base_addr = cfg->c_addr;

    cfg->c_addr = base_addr;
    cfg->x_addr = base_addr + cfg->n;

    bm_printf("Loading input test data DIRECTLY to xmem, byte length : %d\n",
              total_bytes);

    bm_printf("Direct xmem layout:\n");
    bm_printf("c_addr : 0x%08x\n", (unsigned int)(uintptr_t)cfg->c_addr);
    bm_printf("x_addr : 0x%08x\n", (unsigned int)(uintptr_t)cfg->x_addr);
    bm_printf("y_addr : 0x%08x\n", (unsigned int)(uintptr_t)cfg->y_addr);
    bm_printf("\n");

    bm_start_soc_load_hex_file(data_f, total_bytes, (unsigned char*)cfg->c_addr);
    while (!bm_check_soc_load_hex_file());

    int32_t sum_c = 0;
    int32_t sum_x = 0;

    for (int i = 0; i < cfg->n; i++) {
        sum_c += cfg->c_addr[i];
        sum_x += cfg->x_addr[i];
    }

    bm_printf("===== C APP LOADED VECTOR CHECK =====\n");
    bm_printf("SUM_C = %d\n", sum_c);
    bm_printf("SUM_X = %d\n", sum_x);

    bm_printf("----- C/X FIRST 16 -----\n");
    for (int i = 0; i < 16 && i < cfg->n; i++) {
        bm_printf("APP_BUF[%d] c=%d x=%d\n",
                  i, cfg->c_addr[i], cfg->x_addr[i]);
    }

    bm_printf("----- C/X AROUND 64 -----\n");
    for (int i = 64; i < 72 && i < cfg->n; i++) {
        bm_printf("APP_BUF[%d] c=%d x=%d\n",
                  i, cfg->c_addr[i], cfg->x_addr[i]);
    }

    bm_printf("----- C/X AROUND 128 -----\n");
    for (int i = 128; i < 136 && i < cfg->n; i++) {
        bm_printf("APP_BUF[%d] c=%d x=%d\n",
                  i, cfg->c_addr[i], cfg->x_addr[i]);
    }

    bm_printf("----- C/X AROUND 192 -----\n");
    for (int i = 192; i < 200 && i < cfg->n; i++) {
        bm_printf("APP_BUF[%d] c=%d x=%d\n",
                  i, cfg->c_addr[i], cfg->x_addr[i]);
    }

    bm_printf("----- C/X LAST 8 -----\n");
    for (int i = cfg->n - 8; i < cfg->n; i++) {
        bm_printf("APP_BUF[%d] c=%d x=%d\n",
                  i, cfg->c_addr[i], cfg->x_addr[i]);
    }

    bm_printf("\n");
}

/**************** OUTPUT DUMP ****************/

static void dump_fft_conv_output(int dump_f, fft_conv_config_t *cfg) {
    bm_printf("Dumping xmem data at address: 0x%08x , byte length %d\n",
              (unsigned int)(uintptr_t)cfg->y_addr, cfg->n);

    bm_start_soc_store_hex_file(dump_f, cfg->n, 32, (unsigned char*)cfg->y_addr);
    while (!bm_check_soc_store_hex_file());

    bm_printf("Dumped %d bytes\n", cfg->n);
}

/**************** SOFTWARE FFT INFRA ****************/

static void init_infra(int n) {
    for (int k = 0; k < MAX_N / 2; k++) {
        double ang = -2.0 * M_PI * k / MAX_N;

        W[k].re = (int32_t)(cos(ang) * Q15_ONE);
        W[k].im = (int32_t)(sin(ang) * Q15_ONE);
    }

    int log2n = 0;

    for (int t = n; t > 1; t >>= 1) {
        log2n++;
    }

    for (int i = 0; i < n; i++) {
        uint32_t r = 0;
        uint32_t x = i;

        for (int b = 0; b < log2n; b++) {
            r = (r << 1) | (x & 1);
            x >>= 1;
        }

        bit_rev_table[i] = (uint8_t)r;
    }
}

/**************** XLR ****************/

void fft_conv_xlr(fft_conv_config_t *cfg) {
    bm_printf("Writing XLR registers:\n");
    bm_printf("FFT_C_ADDR = 0x%08x\n", (unsigned int)(uintptr_t)cfg->c_addr);
    bm_printf("FFT_X_ADDR = 0x%08x\n", (unsigned int)(uintptr_t)cfg->x_addr);
    bm_printf("FFT_Y_ADDR = 0x%08x\n", (unsigned int)(uintptr_t)cfg->y_addr);
    bm_printf("FFT_N      = %d\n", cfg->n);
    bm_printf("FFT_MODE   = %d\n\n", cfg->mode);

    *FFT_C_ADDR_REG = (unsigned int) cfg->c_addr;
    *FFT_X_ADDR_REG = (unsigned int) cfg->x_addr;
    *FFT_Y_ADDR_REG = (unsigned int) cfg->y_addr;
    *FFT_N_REG      = (unsigned int) cfg->n;
    *FFT_MODE_REG   = (unsigned int) cfg->mode;

    *FFT_START_REG = 1;

    while (!*FFT_DONE_REG) {
        // wait
    }
}

/**************** SOFTWARE FFT ****************/

static void fft_inplace_q15(cq15 *a, int n, int inverse) {
    for (int i = 0; i < n; i++) {
        int j = bit_rev_table[i];

        if (j > i) {
            cq15 tmp = a[i];
            a[i] = a[j];
            a[j] = tmp;
        }
    }

    for (int len = 2; len <= n; len <<= 1) {
        int half = len >> 1;
        int step = MAX_N / len;

        for (int i = 0; i < n; i += len) {
            for (int j = 0; j < half; j++) {
                cq15 w = W[j * step];

                if (inverse) {
                    w.im = -w.im;
                }

                cq15 u = a[i + j];
                cq15 v = cq15_mul(a[i + j + half], w);

                a[i + j].re = (u.re + v.re) >> 1;
                a[i + j].im = (u.im + v.im) >> 1;

                a[i + j + half].re = (u.re - v.re) >> 1;
                a[i + j + half].im = (u.im - v.im) >> 1;
            }
        }
    }
}

/**************** SOFTWARE CONVOLUTION ****************/

static void fft_conv_sw(fft_conv_config_t *cfg) {
    int n = cfg->n;

    static cq15 A[MAX_N];
    static cq15 B[MAX_N];
    static cq15 Out[MAX_N];

    static int32_t tmp_fft[MAX_N];
    static int32_t tmp_naive[MAX_N];

    /******** Naive circular convolution ********/

    if (cfg->mode != 1) {
        for (int i = 0; i < n; i++) {
            int32_t sum = 0;

            for (int k = 0; k < n; k++) {
                int x_idx = (i - k + n) % n;

                sum += (int32_t)cfg->c_addr[k] *
                       (int32_t)cfg->x_addr[x_idx];
            }

            tmp_naive[i] = sum;
        }
    }

    /******** FFT circular convolution ********/

    if (cfg->mode != 0) {
        for (int i = 0; i < n; i++) {
            A[i].re = (int32_t)cfg->c_addr[i] << 12;
            A[i].im = 0;

            B[i].re = (int32_t)cfg->x_addr[i] << 12;
            B[i].im = 0;
        }

        fft_inplace_q15(A, n, 0);
        fft_inplace_q15(B, n, 0);

        for (int i = 0; i < n; i++) {
            Out[i] = cq15_mul(A[i], B[i]);
        }

        fft_inplace_q15(Out, n, 1);

        for (int i = 0; i < n; i++) {
            tmp_fft[i] = Out[i].re;
        }
    }

    /******** Scaling ********/

    int32_t max_naive = 0;
    int32_t max_fft = 0;

    if (cfg->mode != 1) {
        for (int i = 0; i < n; i++) {
            int32_t v = abs_s32_c(tmp_naive[i]);

            if (v > max_naive) {
                max_naive = v;
            }
        }
    }

    if (cfg->mode != 0) {
        for (int i = 0; i < n; i++) {
            int32_t v = abs_s32_c(tmp_fft[i]);

            if (v > max_fft) {
                max_fft = v;
            }
        }
    }

    int32_t max_all = (max_naive > max_fft) ? max_naive : max_fft;

    if (max_all == 0) {
        max_all = 1;
    }

    for (int i = 0; i < n; i++) {
        int32_t res;

        if (cfg->mode == 0) {
            res = tmp_naive[i];
        }
        else {
            res = tmp_fft[i];
        }

        int32_t q = (res * 127) / max_all;

        if (q > 127) {
            q = 127;
        }

        if (q < -128) {
            q = -128;
        }

        cfg->y_addr[i] = (int8_t)q;
    }
}

/**************** MAIN ****************/

int main() {
    bm_printf("\nFFT_CONV FIXED POINT STARTED\n");

    int data_f = bm_fopen_r("fft_test_in.txt");
    int cfg_f  = bm_fopen_r("fft_test_config.txt");
    int out_f  = bm_fopen_w("fft_test_out.txt");

    fft_conv_config_t cfg;

    load_fft_conv_config(cfg_f, &cfg);
    load_fft_conv_input_data(data_f, &cfg);

    boolean is_xlr_enabled = FALSE;

#ifdef XON
    is_xlr_enabled = TRUE;
#endif

#ifdef XOFF
    is_xlr_enabled = FALSE;
#endif

    if (is_xlr_enabled) {
        bm_printf("\nAccelerator Enabled\n");
    }
    else {
        bm_printf("\nAccelerator Disabled\n");
    }

    int start_cycle;
    int end_cycle;

    ENABLE_CYCLE_COUNT;
    RESET_CYCLE_COUNT;

    GET_CYCLE_COUNT_START(start_cycle);

    if (is_xlr_enabled) {
        fft_conv_xlr(&cfg);
    }
    else {
        init_infra(cfg.n);
        fft_conv_sw(&cfg);
    }

    GET_CYCLE_COUNT_END(end_cycle);

    bm_printf("\n*** Measured execution time: %d cycles ***\n\n",
              end_cycle - start_cycle);

    dump_fft_conv_output(out_f, &cfg);

    bm_quit_app();

    return 0;
}
